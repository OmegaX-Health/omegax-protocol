/// `allocate_capital` - Anchor facade forwarder.
/// Implementation: `crate::capital::allocate_capital`; accounts context: `AllocateCapital`.
handler allocate_capital (args : AllocateCapitalArgs) : State.Live -> State.Live {
  auth authority

  accounts {
    authority           : signer
    protocol_governance : readonly
    liquidity_pool      : writable
    capital_class       : writable
    pool_class_ledger   : writable
    funding_line        : readonly
    allocation_position : writable
    allocation_ledger   : writable
  }

  requires emergency_pause == 0 else ProtocolEmergencyPaused
  requires args.amount > 0 else AmountMustBePositive

  // SPEC-REFINE: bind allocation capacity deltas to free reserve/class capacity.
  effect {
    allocated_amount +=! 1
    allocated_assets +=! 1
    total_allocated +=! 1
    audit_nonce +=! 1
  }
}

/// `deallocate_capital` - Anchor facade forwarder.
/// Implementation: `crate::capital::deallocate_capital`; accounts context: `DeallocateCapital`.
handler deallocate_capital (args : DeallocateCapitalArgs) : State.Live -> State.Live {
  auth authority

  accounts {
    authority           : signer
    protocol_governance : readonly
    liquidity_pool      : writable
    capital_class       : writable
    pool_class_ledger   : writable
    funding_line        : readonly
    allocation_position : writable
    allocation_ledger   : writable
  }

  requires emergency_pause == 0 else ProtocolEmergencyPaused
  requires args.amount > 0 else AmountMustBePositive

  // SPEC-REFINE: bind allocation capacity deltas to free reserve/class capacity.
  effect {
    allocated_amount -=! 1
    allocated_assets -=! 1
    total_allocated -=! 1
    audit_nonce +=! 1
  }
}

/// `mark_impairment` - Anchor facade forwarder.
/// Implementation: `crate::capital::mark_impairment`; accounts context: `MarkImpairment`.
handler mark_impairment (args : MarkImpairmentArgs) : State.Live -> State.Live {
  auth authority

  accounts {
    authority             : signer
    protocol_governance   : readonly
    health_plan           : readonly
    domain_asset_ledger   : writable
    funding_line          : writable
    funding_line_ledger   : writable
    plan_reserve_ledger   : writable
    series_reserve_ledger : writable
    pool_class_ledger     : writable
    allocation_position   : writable
    allocation_ledger     : writable
    obligation            : writable
  }

  requires emergency_pause == 0 else ProtocolEmergencyPaused
  requires args.amount > 0 else AmountMustBePositive

  // SPEC-REFINE: replace abstract deltas with exact account-field RHS where needed.
  effect {
    updated_at +=! 1
    audit_nonce +=! 1
  }
}

