  preserved_by [adjudicate_claim_case, settle_claim_case, settle_claim_case_selected_asset]

property fee_withdrawals_bounded : withdrawn_fees <= accrued_fees
  preserved_by [withdraw_protocol_fee_spl, withdraw_protocol_fee_sol, withdraw_pool_treasury_spl, withdraw_pool_treasury_sol, withdraw_pool_oracle_fee_spl, withdraw_pool_oracle_fee_sol]

