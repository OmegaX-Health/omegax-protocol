    token_program           : program
  }

  requires emergency_pause == 0 else ProtocolEmergencyPaused
  requires args.shares > 0 else AmountMustBePositive

  // SPEC-CPI: redemption pays the LP net amount after pool-treasury fees.
  transfers {
    from vault_token_account to recipient_token_account amount redemption_net_payout_amount authority domain_asset_vault
  }

  // SPEC-REFINE: bind processed shares to pending queue shares and net payout after fees.
  effect {
    pending_redemption_shares -=! 1
    total_assets -=! 1
    withdrawn_fees +=! 1
    audit_nonce +=! 1
  }
}

